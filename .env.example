# NewsAPI.org — get free key at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# xAI Grok API — get key at https://console.x.ai
GROK_API_KEY=your_grok_api_key_here

# Gmail SMTP — use an App Password (not your Gmail login password)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Who receives the daily digest
RECIPIENT_EMAIL=recipient@example.com

# Optional: comma-separated additional recipients
# RECIPIENT_CC=person2@example.com,person3@example.com

# Schedule time in UTC (used for display only — actual schedule is in trade_intel.yml)
SCHEDULE_UTC=02:00
